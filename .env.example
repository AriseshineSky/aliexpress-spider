# Copy to .env and fill in your values.
#   cp .env.example .env        # Linux / macOS
#   copy .env.example .env      # Windows

# Elasticsearch (optional — omit to write JSONL only)
ELASTICSEARCH_URL=http://user:password@your-es-host:9200
ELASTICSEARCH_INDEX=your_index_name

# Bulk write batch size
ELASTICSEARCH_BULK_CHUNK_SIZE=50

# Optional tuning
# ELASTICSEARCH_TIMEOUT=60
# ELASTICSEARCH_MAX_RETRY=3
